# Provenance — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# Anthropic (required for v1)
ANTHROPIC_API_KEY=

# OpenAI (stubbed in v1, required for v2)
OPENAI_API_KEY=

# Google Gemini (stubbed in v1, required for v2)
GEMINI_API_KEY=

# Database
DATABASE_URL=sqlite:///./provenance.db

# App
APP_ENV=development
LOG_LEVEL=INFO
